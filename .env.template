# .env.template — safe to commit
# After cloning, copy this to .env and fill in your values:
# Then edit .env with your own credentials

# ── Browser ────────────────────────────────────────────────
# Options: chrome, chrome-headless, firefox, firefox-headless, edge
BROWSER=chrome
HEADLESS=false

# ── Application ────────────────────────────────────────────
BASE_URL=https://www.linkedin.com

# ── Timeouts (seconds) ─────────────────────────────────────
EXPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30

# ── LinkedIn credentials — fill in your own ───────────────
LINKEDIN_USERNAME=your-email@example.com
LINKEDIN_PASSWORD=your-password